problema 1

graph TD
    Start((Inicio)) --> Init[Inicializar Hora=0, Cola=0, PS=Libre]
    Init --> FEL[Programar Primera Llegada en FEL]
    FEL --> Loop{¿Evento en FEL?}
    Loop -- Si --> Event[Extraer Evento más próximo]
    Event --> Type{Tipo de Evento}
    
    Type -- Llegada --> Arr[Programar Siguiente Llegada]
    Arr --> Busy{¿PS Ocupado?}
    Busy -- Si --> Q[Cola = Cola + 1]
    Busy -- No --> StartS[PS = Ocupado, Programar Fin Servicio]
    
    Type -- Fin Servicio --> EndS[PS = Libre]
    EndS --> QEmpty{¿Cola > 0?}
    QEmpty -- Si --> Next[Cola = Cola - 1, PS = Ocupado, Programar Fin Servicio]
    QEmpty -- No --> Loop
    
    Q --> Loop
    StartS --> Loop
    Next --> Loop
    Loop -- No --> End((Fin))

problema 2

graph TD
    Type -- Salida Servidor --> SOut[Presencia = 0, Programar Llegada Servidor]
    Type -- Llegada Servidor --> SIn[Presencia = 1, Programar Salida Servidor]
    SIn --> CheckQ{¿Cola > 0?}
    CheckQ -- Si --> StartS[PS = Ocupado, Programar Fin Servicio]
    
    Type -- Fin Servicio --> Free[PS = Libre]
    Free --> CheckS{¿Presencia == 1 Y Cola > 0?}
    CheckS -- Si --> Next[Atender Siguiente]


